# Test trigger event
trigger userLogin

# Test array/list operations
var numbers: List = [1, 2, 3, 4, 5]
var total = 0
var j = 0
while (j < numbers.length) {
    total = total + numbers[j]
    j = j + 1
}
print("Sum of numbers: " + total)

# Test string operations
var message = "FlowLang is awesome!"
var length = message.length
print("Message length: " + length)

# Test boolean operations
var condition1 = true
var condition2 = false
var result1 = condition1 and condition2
var result2 = condition1 or condition2
var result3 = not condition1

print("True and False: " + result1)
print("True or False: " + result2)
print("Not True: " + result3)

print("🎯 FlowLang test completed successfully!")
print("✨ All syntax highlighting should be working perfectly!")
